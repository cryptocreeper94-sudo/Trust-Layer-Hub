# Trust Layer Hub — Environment Variables
# ========================================

# ── Database ──────────────────────────────────────────
DATABASE_URL=

# ── Firebase (Server) ────────────────────────────────
# Paste your Firebase service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=

# ── Firebase (Client / Expo) ─────────────────────────
# These are public-safe keys from Firebase Console > Project Settings
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google Sign-In ───────────────────────────────────
# Web client ID from Firebase Console > Authentication > Sign-in method > Google
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=

# ── SMS 2FA (Twilio) ────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Payments (Stripe) ───────────────────────────────
STRIPE_SECRET_KEY=

# ── AI (OpenAI) ──────────────────────────────────────
OPENAI_API_KEY=
