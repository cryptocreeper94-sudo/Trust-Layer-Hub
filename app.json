{
  "expo": {
    "name": "Trust Layer",
    "slug": "trust-layer-hub",
    "owner": "darkwavestudios",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trustlayer",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c1224"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.trustlayer.hub"
    },
    "android": {
      "package": "io.trustlayer.hub",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "*.dwtl.io",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "dwtl.io",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0c1224",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "name": "Trust Layer Hub",
      "shortName": "Trust Layer",
      "description": "The front door to the Trust Layer blockchain ecosystem",
      "themeColor": "#0c1224",
      "backgroundColor": "#0c1224"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://trusthub.tlid.io"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
